        item.classList.remove('active');
      });
      const activeItem = document.querySelector(`[data-page="${pageId}"]`);
      if (activeItem) {
        activeItem.classList.add('active');
      }
    }

    document.querySelectorAll('.nav-item.parent').forEach(parentItem => {
      parentItem.addEventListener('click', function() {
        const section = this.closest('.nav-section');
        if (!section) return;
        const submenu = section.querySelector('.nav-submenu');
        if (!submenu) return;
        submenu.classList.toggle('expanded');
        this.classList.toggle('expanded');
      });
    });

    document.querySelectorAll('.nav-item.child').forEach(childItem => {
      childItem.addEventListener('click', function(event) {
        event.stopPropagation();
        const pageId = this.getAttribute('data-page');
        if (pageId) {
          showPage(pageId);
        }
      });
    });

    document.querySelectorAll('.nav-item[data-page]:not(.parent):not(.child)').forEach(item => {
      item.addEventListener('click', function(event) {
        event.stopPropagation();
        const pageId = this.getAttribute('data-page');
        if (pageId) {
          showPage(pageId);
        }
      });
    });
  </script>
</body>
