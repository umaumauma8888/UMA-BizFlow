  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <script>
    const salesData = [
      { invoice: 'INV-1001', date: '2026-01-05', customer: '株式会社ABC', amount: 180000, taxRate: 0.10 },
      { invoice: 'INV-1002', date: '2026-01-19', customer: '株式会社DEF', amount: 95000, taxRate: 0.08 },
      { invoice: 'INV-1003', date: '2026-02-03', customer: '株式会社GHI', amount: 240000, taxRate: 0.10 },
      { invoice: 'INV-1004', date: '2026-02-15', customer: '株式会社JKL', amount: 126000, taxRate: 0.10 },
      { invoice: 'INV-1005', date: '2026-03-01', customer: '株式会社MNO', amount: 76000, taxRate: 0.08 },
      { invoice: 'INV-1006', date: '2026-03-09', customer: '株式会社PQR', amount: 320000, taxRate: 0.10 },
      { invoice: 'INV-1007', date: '2026-03-20', customer: '株式会社STU', amount: 142000, taxRate: 0.08 },
      { invoice: 'INV-1008', date: '2026-04-02', customer: '株式会社VWX', amount: 210000, taxRate: 0.10 },
      { invoice: 'INV-1009', date: '2026-04-10', customer: '株式会社YZA', amount: 98000, taxRate: 0.08 },
      { invoice: 'INV-1010', date: '2026-04-18', customer: '株式会社BCD', amount: 174000, taxRate: 0.10 }
    ];

    function formatYen(value) {
      return '¥' + value.toLocaleString();
    }

    function aggregateSales() {
      return salesData.reduce((acc, item) => {
        acc.total += item.amount;
        if (item.taxRate === 0.10) {
          acc.tax10 += Math.round(item.amount * 0.10);
        }
        if (item.taxRate === 0.08) {
          acc.tax8 += Math.round(item.amount * 0.08);
        }
        return acc;
      }, { total: 0, tax10: 0, tax8: 0 });
    }

    function buildMonthlySales() {
      const monthMap = {};
      salesData.forEach(item => {
        const monthKey = item.date.slice(0, 7);
        monthMap[monthKey] = (monthMap[monthKey] || 0) + item.amount;
      });
      const labels = Object.keys(monthMap).sort();
      const values = labels.map(label => monthMap[label]);
      return { labels, values };
    }

    function renderLedger() {
      const body = document.getElementById('ledger-body');
      if (!body) return;
      body.innerHTML = salesData.map(item => `
        <tr>
          <td>${item.date}</td>
          <td>${item.customer}</td>
          <td>${formatYen(item.amount)}</td>
          <td>${item.taxRate * 100}%</td>
        </tr>
      `).join('');
    }

    function renderSalesReport() {
      const summary = aggregateSales();
      document.getElementById('report-total-sales').textContent = formatYen(summary.total);
      document.getElementById('report-invoice-count').textContent = salesData.length;
      document.getElementById('report-tax10').textContent = formatYen(summary.tax10);
      document.getElementById('report-tax8').textContent = formatYen(summary.tax8);

      const reportBody = document.getElementById('report-sales-body');
      if (reportBody) {
        reportBody.innerHTML = salesData.slice().reverse().map(item => `
          <tr>
            <td>${item.invoice}</td>
            <td>${item.date}</td>
            <td>${item.customer}</td>
            <td>${formatYen(item.amount)}</td>
            <td>${item.taxRate * 100}%</td>
          </tr>
        `).join('');
      }
    }

    function renderAccountingSummary() {
      const summary = aggregateSales();
      document.getElementById('invoice-total').textContent = formatYen(summary.total);
      document.getElementById('invoice-tax10').textContent = formatYen(summary.tax10);
      document.getElementById('invoice-tax8').textContent = formatYen(summary.tax8);
      document.getElementById('invoice-count').textContent = salesData.length;
      renderLedger();
    }

    function renderDashboardSummary() {
      const summary = aggregateSales();
      const currentMonth = '2026-04';
      const currentMonthSales = salesData
        .filter(item => item.date.startsWith(currentMonth))
        .reduce((sum, item) => sum + item.amount, 0);
      const currentMonthOrders = salesData.filter(item => item.date.startsWith(currentMonth)).length;
      document.getElementById('dashboard-today-sales').textContent = formatYen(currentMonthSales);
      document.getElementById('dashboard-open-tasks').textContent = '5';
      document.getElementById('dashboard-orders').textContent = currentMonthOrders;
      document.getElementById('dashboard-delinquencies').textContent = '3';
      if (document.getElementById('dashboardSalesChart')) {
        const chartData = buildMonthlySales();
        const ctx = document.getElementById('dashboardSalesChart').getContext('2d');
        new Chart(ctx, {
          type: 'bar',
          data: {
            labels: chartData.labels,
            datasets: [{
              label: '月別売上',
              data: chartData.values,
              backgroundColor: 'rgba(56,189,248,0.8)',
              borderColor: 'rgba(56,189,248,1)',
              borderWidth: 1,
              borderRadius: 6
            }]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              x: { grid: { display: false }, ticks: { color: '#64748B' } },
              y: { ticks: { color: '#64748B', callback: value => '¥' + value.toLocaleString() }, grid: { color: 'rgba(148,163,184,0.2)' } }
            },
            plugins: { legend: { display: false } }
          }
        });
      }
    }

    function renderAIAdvisor() {
      const commentContainer = document.createElement('div');
      commentContainer.style.marginTop = '16px';
      commentContainer.innerHTML = `
        <div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;padding:18px;">
          <div style="font-size:14px;font-weight:600;color:#0f172a;margin-bottom:10px;">AI分析コメント</div>
          <p style="font-size:13px;color:#334155;line-height:1.7;margin-bottom:10px;">今月は先月比で10%売上が向上しています。特にB2Bの受注が好調で、請求書の回収速度も改善しています。</p>
          <p style="font-size:13px;color:#334155;line-height:1.7;">インボイス10%の売上が全体の55%を占めており、消費税10%対応の入金処理を優先するとキャッシュフローが安定します。</p>
        </div>
      `;
      const aiAdvisorPage = document.getElementById('ai-advisor');
      if (aiAdvisorPage) {
        aiAdvisorPage.appendChild(commentContainer);
      }
    }

    function showPage(pageId) {
      document.querySelectorAll('.screen').forEach(screen => {
        screen.classList.remove('active');
      });
      const targetScreen = document.getElementById(pageId);
      if (targetScreen) {
        targetScreen.classList.add('active');
      }
      const pageTitles = {
        'dashboard': 'ダッシュボード',
        'customers-list': '顧客一覧',
        'customers-new': '顧客新規登録',
        'customers-history': '対応履歴',
        'orders-quote': '見積書作成',
        'orders-list': '受注一覧',
        'orders-delivery': '納品管理',
        'billing-create': '請求書発行',
        'billing-payment': '入金消込・管理',
        'billing-reminder': '支払督促',
        'accounting': '会計・財務',
        'sales-report': '売上レポート',
        'user-management': 'ユーザー管理',
        'system-settings': 'システム設定',
        'ai-chat': 'AIチャット',
        'ai-advisor': 'AI経営参謀'
      };
      const titleElement = document.querySelector('.page-title');
      if (titleElement && pageTitles[pageId]) {
        titleElement.textContent = pageTitles[pageId];
      }
      document.querySelectorAll('.nav-item').forEach(item => {
        item.classList.remove('active');
      });
      const activeItem = document.querySelector(`[data-page="${pageId}"]`);
      if (activeItem) {
        activeItem.classList.add('active');
      }
    }

    document.querySelectorAll('.nav-item.parent').forEach(parentItem => {
      parentItem.addEventListener('click', function() {
        const section = this.closest('.nav-section');
        if (!section) return;
        const submenu = section.querySelector('.nav-submenu');
        if (!submenu) return;
        submenu.classList.toggle('expanded');
        this.classList.toggle('expanded');
      });
    });

    document.querySelectorAll('.nav-item.child').forEach(childItem => {
      childItem.addEventListener('click', function(event) {
        event.stopPropagation();
        const pageId = this.getAttribute('data-page');
        if (pageId) {
          showPage(pageId);
        }
      });
    });

    document.querySelectorAll('.nav-item[data-page]:not(.parent):not(.child)').forEach(item => {
      item.addEventListener('click', function(event) {
        event.stopPropagation();
        const pageId = this.getAttribute('data-page');
        if (pageId) {
          showPage(pageId);
        }
      });
    });

    renderAccountingSummary();
    renderSalesReport();
    renderDashboardSummary();
    renderAIAdvisor();
  </script>
